@model InvitedPerson

<div class="container p-3">
    <div class="row">
        <h2 class="text-primary">Delete guest</h2>
    </div>
    <form method="post" asp-action="DeletePost">
        <input asp-for="@Model.Id" hidden />
        <div class="form-group">
            <label asp-for="Name">Name</label>
            <input asp-for="Name" disabled type="text" class="form-control" placeholder="Name">
        </div>
        <div class="form-group">
            <label asp-for="Email">Email address</label>
            <input asp-for="Email" disabled type="email" class="form-control" placeholder="Email">
        </div>
        <div class="form-group">
            <label asp-for="PhoneNumber">Phone</label>
            <input asp-for="PhoneNumber" disabled type="text" class="form-control" placeholder="Phone">
        </div>
        <div class="form-group">
            <label asp-for="Comments">Comments</label>
            <input asp-for="Comments" disabled type="text" class="form-control" placeholder="Comments">
        </div>
        @*<div class="form-check">
            <input asp-for="RSVP" type="checkbox" class="form-check-input" id="exampleCheck1">
            <label asp-for="RSVP"  for="exampleCheck1">If the guest has already accepted the invitation, please check the box.</label>
        </div>*@
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-controller="CreateEvent" asp-action="Index" button type="submit" class="btn btn-primary">Go back</a>
    </form>
</div>

